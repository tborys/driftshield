# API auth for local development
ENVIRONMENT=development
API_KEY=dev-api-key
MAX_REQUEST_BYTES=26214400

# Local DB defaults (matches docker-compose.dev.yml)
DATABASE_URL=postgresql://drift:drift@localhost:5432/driftshield

# Optional: the CLI reads these when talking to a running API instead of the
# local database directly. Uncomment and adjust if you ingest over HTTP.
# DRIFTSHIELD_API_URL=http://localhost:8080
# DRIFTSHIELD_API_KEY=dev-api-key
