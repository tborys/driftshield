# DriftShield dogfood VPS production example
# Copy to driftshield/.env on the VPS and replace all placeholder values.

ENVIRONMENT=production

# API auth
API_KEY=replace-with-a-long-random-api-key

# Database
DB_USER=drift
DB_PASSWORD=replace-with-a-strong-db-password
DB_NAME=driftshield
DATABASE_URL=postgresql://drift:replace-with-a-strong-db-password@db:5432/driftshield

# Application
PORT=8080
LOG_LEVEL=info
WORKERS=1
MAX_REQUEST_BYTES=26214400

# Optional graveyard report path override
GRAVEYARD_REPORT_PATH=data/graveyard/report.md
